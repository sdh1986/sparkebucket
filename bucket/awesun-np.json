    "installer": {
        "script": [
            "$exe = Get-ChildItem \"$dir\\SunloginClient_*.exe\" | Select-Object -First 1",
            "if ($exe) {",
            "    Write-Host '==> 正在尝试后台静默安装向日葵远程控制 (可能被官方安全策略拦截并弹窗)...' -ForegroundColor Cyan",
            "    $processOptions = @{",
            "        FilePath     = $exe.FullName",
            "        ArgumentList = '/S', '/VERYSILENT', '/quiet'",
            "        WindowStyle  = 'Hidden'",
            "        Wait         = $true",
            "    }",
            "    Start-Process @processOptions",
            "}",
            "$path = 'HKCU:\\Software\\Oray\\SunLogin\\SunloginClient'",
            "New-Item $path -ErrorAction SilentlyContinue -Force | Out-Null",
            "New-ItemProperty -Path $path -Name \"${version}_IsRunSeted\" -Value \"1\" -PropertyType String -ErrorAction SilentlyContinue"
