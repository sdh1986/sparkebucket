{
    "version": "5.36.0",
    "description": "Sinopharm WPS Collaboration (国药协作 WOA/xiezuo)",
    "homepage": "https://woa.wps.cn",
    "license": "Proprietary",
    "url": "https://woa.wps.cn/favicon.ico#/dummy.ico",
    "hash": "cf233f7d57b7ad1e5623c290c9bdf39d4d26a05ab131d329b81d75bd0d5b8f2d",
    "installer": {
        "script": [
            "$ProgressPreference = 'SilentlyContinue'",
            "Write-Host 'Bypassing Scoop restrictions to fetch installer dynamically...' -ForegroundColor Cyan",
            "$userAgent = 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36'",
            "$dlUrl = 'https://woa.wps.cn/publish/bin/download?channel=sinopharm&platform=win'",
            "try {",
            "    Write-Host 'Downloading Xiezuo installer from official server (this may take a moment)...' -ForegroundColor Yellow",
            "    Invoke-WebRequest -Uri $dlUrl -OutFile \"$dir\\xiezuo-setup.exe\" -UserAgent $userAgent",
            "    Write-Host 'Download successful!' -ForegroundColor Green",
            "} catch {",
            "    Write-Host \"Download failed: $_\" -ForegroundColor Red",
            "    exit 1",
            "}",
            "",
            "Write-Host 'Closing running Xiezuo processes to prevent installation hang...' -ForegroundColor Cyan",
            "Get-Process -Name 'xiezuo*', 'woa*' -ErrorAction SilentlyContinue | Stop-Process -Force -ErrorAction SilentlyContinue",
            "Write-Host 'Starting WPS Xiezuo GUI installer...' -ForegroundColor Cyan",
            "Write-Host 'Please follow the on-screen graphical instructions to complete the installation.' -ForegroundColor Yellow",
            "if (Test-Path \"$dir\\xiezuo-setup.exe\") {",
            "    Start-Process -FilePath \"$dir\\xiezuo-setup.exe\" -WorkingDirectory \"$dir\" -Verb RunAs",
            "    Start-Sleep -Seconds 5",
            "    $setupProcName = [System.IO.Path]::GetFileNameWithoutExtension(\"$dir\\xiezuo-setup.exe\")",
            "    while (Get-Process -Name $setupProcName, 'setup' -ErrorAction SilentlyContinue) { Start-Sleep -Seconds 2 }",
            "} else {",
            "    Write-Host 'Installer executable not found.' -ForegroundColor Red",
            "}",
            "Write-Host 'Installation GUI closed. Cleaning up background services...' -ForegroundColor Cyan",
            "Get-Process -Name 'xiezuo*', 'woa*' -ErrorAction SilentlyContinue | Stop-Process -Force -ErrorAction SilentlyContinue",
            "Remove-Item \"$dir\\xiezuo-setup.exe\" -Force -ErrorAction SilentlyContinue",
            "Write-Host 'WPS Xiezuo installation process finished.' -ForegroundColor Green"
        ]
    },
    "uninstaller": {
        "script": [
            "Write-Host 'Searching for Xiezuo uninstaller...' -ForegroundColor Cyan",
            "$uninst = $null",
            "$regPaths = @('HKLM:\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\*', 'HKLM:\\SOFTWARE\\WOW6432Node\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\*', 'HKCU:\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\*')",
            "$woaReg = Get-ItemProperty $regPaths -ErrorAction SilentlyContinue | Where-Object { $_.DisplayName -match '协作|xiezuo' -and $_.UninstallString } | Select-Object -First 1",
            "if ($woaReg) {",
            "    if ($woaReg.UninstallString -match '\\\"(.*?\\.exe)\\\"') { $uninst = $matches[1] }",
            "    elseif ($woaReg.UninstallString -match '(.*?\\.exe)') { $uninst = $matches[1] }",
            "}",
            "if (-not $uninst -or -not (Test-Path $uninst)) {",
            "    $baseDirs = @(\"$env:LOCALAPPDATA\\xiezuo\", \"$env:ProgramFiles\\xiezuo\", \"${env:ProgramFiles(x86)}\\xiezuo\")",
            "    foreach ($dir in $baseDirs) { if (Test-Path $dir) { $found = Get-ChildItem -Path $dir -Filter 'uninst*.exe' -Recurse -ErrorAction SilentlyContinue | Select-Object -First 1; if ($found) { $uninst = $found.FullName; break } } }",
            "}",
            "if ($uninst -and (Test-Path $uninst)) {",
            "    Write-Host \"Uninstaller found: $uninst\" -ForegroundColor Green",
            "    Write-Host 'Please follow the uninstaller GUI to remove Xiezuo.' -ForegroundColor Yellow",
            "    $uninstName = [System.IO.Path]::GetFileNameWithoutExtension($uninst)",
            "    Start-Process -FilePath $uninst -Verb RunAs",
            "    Start-Sleep -Seconds 3",
            "    while (Get-Process -Name $uninstName -ErrorAction SilentlyContinue) { Start-Sleep -Seconds 2 }",
            "    Write-Host 'Uninstall GUI closed. Process finished.' -ForegroundColor Green",
            "} else {",
            "    Write-Host 'Xiezuo uninstaller not found.' -ForegroundColor Red",
            "}"
        ]
    },
    "checkver": {
        "url": "https://woa.wps.cn/bin/version?platform=win&channel=sinopharm",
        "regex": "\"app_name\"\\s*:\\s*\".*?(?<version>\\d+\\.\\d+\\.\\d+).*?\""
    }
}
