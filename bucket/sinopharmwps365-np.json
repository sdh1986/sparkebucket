{
    "version": "12.1.0.20305",
    "description": "Sinopharm Personal WPS 365",
    "homepage": "https://www.wps.cn",
    "license": "Proprietary",
    "url": "https://wpsplus-prod.ks3-cn-beijing.ksyun.com/wps_windows_custom_pack_1776909618866072781/sinopharm-sn-setup_CN_2052_12.1.0.20305_Personal_WPS365_international51.854.exe?Expires=1792461810&AWSAccessKeyId=AKLTFlK09C54QAiYpBcdt9Sn&Signature=23JcIfJf7ZpqODjvUkIHQFQ6GbA%3D#/wps-setup.exe",
    "hash": "D0292FA3E4572FE199875B9D1DD615A859461A828EA7ED3126608F3CB225265E",
    "installer": {
        "script": [
            "Write-Host 'Preparing installation environment...' -ForegroundColor Cyan",
            "$tmpScript = \"$dir\\_install_wrapper.ps1\"",
            "$code = @(",
            "    '$ErrorActionPreference = ''SilentlyContinue'';',",
            "    'Write-Host ''Force closing WPS background processes...'' -ForegroundColor Cyan;',",
            "    'taskkill /F /T /IM wps*.exe /IM wpp*.exe /IM et*.exe /IM kso*.exe /IM wpscloudsvr.exe /IM wpscloudsrv.exe /IM wpscenter.exe | Out-Null;',",
            "    'Start-Sleep -Seconds 1;',",
            "    'Write-Host ''Starting WPS Installer...'' -ForegroundColor Cyan;',",
            "    '$p = Start-Process -FilePath \"' + $dir + '\\wps-setup.exe\" -WorkingDirectory \"' + $dir + '\" -PassThru;',",
            "    'while (-not $p.HasExited) { Start-Sleep -Seconds 2 }'",
            ") -join \"`r`n\"",
            "Set-Content -Path $tmpScript -Value $code -Encoding utf8",
            "Write-Host 'Please accept the UAC prompt and follow the on-screen graphical instructions.' -ForegroundColor Yellow",
            "Start-Process -FilePath 'powershell.exe' -ArgumentList \"-NoProfile -ExecutionPolicy Bypass -WindowStyle Normal -File `\"$tmpScript`\"\" -Verb RunAs -Wait",
            "Remove-Item $tmpScript -Force -ErrorAction SilentlyContinue",
            "Write-Host 'WPS installation process finished.' -ForegroundColor Green"
        ]
    },
    "uninstaller": {
        "script": [
            "Write-Host 'Searching for WPS uninstaller...' -ForegroundColor Cyan",
            "$uninst = $null",
            "$regPaths = @('HKLM:\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\*', 'HKLM:\\SOFTWARE\\WOW6432Node\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\*', 'HKCU:\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\*')",
            "$wpsReg = Get-ItemProperty $regPaths -ErrorAction SilentlyContinue | Where-Object { $_.DisplayName -match 'WPS' -and $_.UninstallString } | Select-Object -First 1",
            "if ($wpsReg) {",
            "    if ($wpsReg.UninstallString -match '\\\"(.*?\\.exe)\\\"') { $uninst = $matches[1] }",
            "    elseif ($wpsReg.UninstallString -match '(.*?\\.exe)') { $uninst = $matches[1] }",
            "}",
            "if (-not $uninst -or -not (Test-Path $uninst)) {",
            "    $baseDirs = @(\"$env:LOCALAPPDATA\\Kingsoft\\WPS Office\", \"$env:ProgramFiles\\Kingsoft\\WPS Office\", \"${env:ProgramFiles(x86)}\\Kingsoft\\WPS Office\", \"$env:LOCALAPPDATA\\WPS Office\", \"$env:ProgramFiles\\WPS Office\")",
            "    foreach ($d in $baseDirs) { if (Test-Path $d) { $found = Get-ChildItem -Path $d -Filter 'uninst.exe' -Recurse -ErrorAction SilentlyContinue | Select-Object -First 1; if ($found) { $uninst = $found.FullName; break } } }",
            "}",
            "if ($uninst -and (Test-Path $uninst)) {",
            "    Write-Host \"Uninstaller found: $uninst\" -ForegroundColor Green",
            "    $tmpScript = \"$env:TEMP\\_wps_uninstall_wrapper.ps1\"",
            "    $code = @(",
            "        '$ErrorActionPreference = ''SilentlyContinue'';',",
            "        'Write-Host ''Force closing WPS processes before uninstall...'' -ForegroundColor Cyan;',",
            "        'taskkill /F /T /IM wps*.exe /IM wpp*.exe /IM et*.exe /IM kso*.exe /IM wpscloudsvr.exe /IM wpscloudsrv.exe /IM wpscenter.exe | Out-Null;',",
            "        'Start-Sleep -Seconds 1;',",
            "        'Write-Host ''Starting WPS Uninstaller...'' -ForegroundColor Cyan;',",
            "        '$p = Start-Process -FilePath \"' + $uninst + '\" -PassThru;',",
            "        'while (-not $p.HasExited) { Start-Sleep -Seconds 2 };',",
            "        'Write-Host ''Cleaning up leftover background processes...'' -ForegroundColor Cyan;',",
            "        'taskkill /F /T /IM wps*.exe /IM wpp*.exe /IM et*.exe /IM kso*.exe /IM wpscloudsvr.exe /IM wpscloudsrv.exe /IM wpscenter.exe | Out-Null;'",
            "    ) -join \"`r`n\"",
            "    Set-Content -Path $tmpScript -Value $code -Encoding utf8",
            "    Write-Host 'Please accept UAC and follow the uninstaller GUI to remove WPS.' -ForegroundColor Yellow",
            "    Start-Process -FilePath 'powershell.exe' -ArgumentList \"-NoProfile -ExecutionPolicy Bypass -WindowStyle Normal -File `\"$tmpScript`\"\" -Verb RunAs -Wait",
            "    Remove-Item $tmpScript -Force -ErrorAction SilentlyContinue",
            "} else {",
            "    Write-Host 'WPS uninstaller not found.' -ForegroundColor Red",
            "}"
        ]
    },
    "checkver": {
        "url": "https://365.kdocs.cn/3rd/plussvr/cmgr/v1/companies/exclusive-pages/GLu5HVcFPyvU7jNj/products?pageId=GLu5HVcFPyvU7jNj&app_name=WPSOffice&system=Windows",
        "jsonpath": "$.package_url",
        "regex": "(?<url>https://.*?(?<version>\\d+\\.\\d+\\.\\d+\\.\\d+).*)"
    },
    "autoupdate": {
        "url": "$matchUrl#/wps-setup.exe",
        "hash": {
            "mode": "download"
        }
    }
}
