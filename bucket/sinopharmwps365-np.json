    "url": "https://wpsplus-prod.ks3-cn-beijing.ksyun.com/wps_windows_custom_pack_1776909618866072781/sinopharm-sn-setup_CN_2052_12.1.0.20305_Personal_WPS365_international51.854.exe?Expires=1792461810&AWSAccessKeyId=AKLTFlK09C54QAiYpBcdt9Sn&Signature=23JcIfJf7ZpqODjvUkIHQFQ6GbA%3D#/wps-setup.exe",
    "hash": "D0292FA3E4572FE199875B9D1DD615A859461A828EA7ED3126608F3CB225265E",
    "installer": {
        "script": [
            "Write-Host '正在启动 WPS 安装程序...' -ForegroundColor Cyan",
            "Write-Host '请注意：任务栏可能会闪烁 UAC 提权提示，请及时点击“是”允许安装！' -ForegroundColor Yellow",
            "Start-Process -Wait -FilePath \"$dir\\wps-setup.exe\" -ArgumentList '/S' -WorkingDirectory \"$dir\" -Verb RunAs | Out-Null",
            "Write-Host 'WPS 安装流程已执行。' -ForegroundColor Cyan",
            "Write-Host '如果桌面未出现快捷方式，它可能已静默安装至 %LOCALAPPDATA%\\Kingsoft\\WPS Office 中。' -ForegroundColor Yellow"
        ]
    },
    "uninstaller": {
        "script": [
            "Write-Host '正在查找并卸载 WPS...' -ForegroundColor Cyan",
            "$uninst = @(",
            "    Get-ChildItem -Path \"$env:ProgramFiles\\WPS Office\\*\\utility\\uninst.exe\" -ErrorAction SilentlyContinue",
            "    Get-ChildItem -Path \"${env:ProgramFiles(x86)}\\WPS Office\\*\\utility\\uninst.exe\" -ErrorAction SilentlyContinue",
            "    Get-ChildItem -Path \"$env:LOCALAPPDATA\\Kingsoft\\WPS Office\\*\\utility\\uninst.exe\" -ErrorAction SilentlyContinue",
            ") | Select-Object -First 1",
            "if ($uninst) {",
            "    Write-Host \"找到卸载程序: $($uninst.FullName)\"",
            "    Start-Process -Wait -FilePath $uninst.FullName -ArgumentList '/S' -Verb RunAs | Out-Null",
            "} else {",
            "    Write-Host '未在默认路径中找到 WPS 卸载程序。' -ForegroundColor Red",
            "}"
        ]
    },
    "checkver": {
        "url": "https://365.kdocs.cn/3rd/plussvr/cmgr/v1/companies/exclusive-pages/GLu5HVcFPyvU7jNj/products?pageId=GLu5HVcFPyvU7jNj&app_name=WPSOffice&system=Windows",
        "jsonpath": "$.package_url",
        "regex": "(?<url>https://.*?(?<version>\\d+\\.\\d+\\.\\d+\\.\\d+).*)"
    },
    "autoupdate": {
        "url": "$matchUrl#/wps-setup.exe",
        "hash": {
            "mode": "download"
        }
    }
}
