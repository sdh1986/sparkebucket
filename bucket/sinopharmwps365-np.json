{
    "version": "12.1.0.20305",
    "description": "Sinopharm Personal WPS 365",
    "homepage": "https://www.wps.cn",
    "license": "Proprietary",
    "url": "https://wpsplus-prod.ks3-cn-beijing.ksyun.com/wps_windows_custom_pack_1776909618866072781/sinopharm-sn-setup_CN_2052_12.1.0.20305_Personal_WPS365_international51.854.exe?Expires=1792461810&AWSAccessKeyId=AKLTFlK09C54QAiYpBcdt9Sn&Signature=23JcIfJf7ZpqODjvUkIHQFQ6GbA%3D#/wps-setup.exe",
    "hash": "D0292FA3E4572FE199875B9D1DD615A859461A828EA7ED3126608F3CB225265E",
    "installer": {
        "script": [
            "Write-Host 'Closing running WPS processes to prevent installation hang...' -ForegroundColor Cyan",
            "Get-Process -Name 'wps*', 'wpp', 'et', 'ksomisc', 'ksolaunch' -ErrorAction SilentlyContinue | Stop-Process -Force",
            "Write-Host 'Starting WPS GUI installer...' -ForegroundColor Cyan",
            "Write-Host 'Please follow the on-screen graphical instructions to complete the installation.' -ForegroundColor Yellow",
            "Start-Process -Wait -FilePath \"$dir\\wps-setup.exe\" -WorkingDirectory \"$dir\" -Verb RunAs | Out-Null",
            "Write-Host 'WPS installation process finished.' -ForegroundColor Cyan"
        ]
    },
    "uninstaller": {
        "script": [
            "Write-Host 'Closing running WPS processes to ensure clean uninstallation...' -ForegroundColor Cyan",
            "# Kill all possible WPS related processes",
            "$wpsProcs = @('wps', 'wpp', 'et', 'wpscloudsvr', 'wpscenter', 'ksomisc', 'ksolaunch', 'kwpsoffice')",
            "foreach ($p in $wpsProcs) { Get-Process -Name $p -ErrorAction SilentlyContinue | Stop-Process -Force }",
            "",
            "Write-Host 'Searching for WPS uninstaller...' -ForegroundColor Cyan",
            "$uninst = $null",
            "",
            "# 1. Try finding uninstaller via Windows Registry",
            "$regPaths = @(",
            "    'HKLM:\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\*',",
            "    'HKLM:\\SOFTWARE\\WOW6432Node\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\*',",
            "    'HKCU:\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\*'",
            ")",
            "$wpsReg = Get-ItemProperty $regPaths -ErrorAction SilentlyContinue | Where-Object { $_.DisplayName -match 'WPS' -and $_.UninstallString } | Select-Object -First 1",
            "if ($wpsReg) {",
            "    if ($wpsReg.UninstallString -match '\\\"(.*?\\.exe)\\\"') { $uninst = $matches[1] }",
            "    elseif ($wpsReg.UninstallString -match '(.*?\\.exe)') { $uninst = $matches[1] }",
            "}",
            "",
            "# 2. Fallback to recursive search in common directories",
            "if (-not $uninst -or -not (Test-Path $uninst)) {",
            "    $baseDirs = @(\"$env:LOCALAPPDATA\\Kingsoft\\WPS Office\", \"$env:ProgramFiles\\Kingsoft\\WPS Office\", \"${env:ProgramFiles(x86)}\\Kingsoft\\WPS Office\", \"$env:LOCALAPPDATA\\WPS Office\", \"$env:ProgramFiles\\WPS Office\")",
            "    foreach ($dir in $baseDirs) {",
            "        if (Test-Path $dir) {",
            "            $found = Get-ChildItem -Path $dir -Filter 'uninst.exe' -Recurse -ErrorAction SilentlyContinue | Select-Object -First 1",
            "            if ($found) { $uninst = $found.FullName; break }",
            "        }",
            "    }",
            "}",
            "",
            "# 3. Execute uninstaller",
            "if ($uninst -and (Test-Path $uninst)) {",
            "    Write-Host \"Uninstaller found: $uninst\" -ForegroundColor Green",
            "    Write-Host 'Please follow the uninstaller GUI to remove WPS.' -ForegroundColor Yellow",
            "    Start-Process -Wait -FilePath $uninst -Verb RunAs | Out-Null",
            "} else {",
            "    Write-Host 'WPS uninstaller not found.' -ForegroundColor Red",
            "}"
        ]
    },
    "checkver": {
        "url": "https://365.kdocs.cn/3rd/plussvr/cmgr/v1/companies/exclusive-pages/GLu5HVcFPyvU7jNj/products?pageId=GLu5HVcFPyvU7jNj&app_name=WPSOffice&system=Windows",
        "jsonpath": "$.package_url",
        "regex": "(?<url>https://.*?(?<version>\\d+\\.\\d+\\.\\d+\\.\\d+).*)"
    },
    "autoupdate": {
        "url": "$matchUrl#/wps-setup.exe",
        "hash": {
            "mode": "download"
        }
    }
}
